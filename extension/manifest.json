{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "version": "0.4.2",
  "homepage_url": "https://github.com/voyvodka/All-in-one-Extension",
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "__MSG_extName__",
    "default_icon": {
      "16": "icons/icon_16.png",
      "32": "icons/icon_32.png"
    }
  },
  "permissions": [
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://youtu.be/*",
    "https://*.youtube-nocookie.com/*",
    "https://*.instagram.com/*",
    "https://*.twitter.com/*",
    "https://twitter.com/*",
    "https://*.x.com/*",
    "https://x.com/*",
    "https://loader.to/*",
    "https://*.loader.to/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://youtu.be/*",
        "https://*.youtube-nocookie.com/*",
        "https://*.instagram.com/*",
        "https://*.twitter.com/*",
        "https://twitter.com/*",
        "https://*.x.com/*",
        "https://x.com/*"
      ],
      "js": [
        "content.js"
      ],
      "type": "module",
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "shared/storage.js",
        "shared/i18n.js",
        "shared/contracts/feature-registry.js",
        "shared/contracts/message-types.js",
        "features/index.js",
        "features/yt-audio-download/content/index.js",
        "features/yt-video-download/content/index.js",
        "features/ig-audio-download/content/index.js",
        "features/ig-video-download/content/index.js",
        "features/ig-image-download/content/index.js",
        "features/ig-unfollowers/content/index.js",
        "features/ig-unfollowers/content/dashboard.js",
        "features/x-audio-download/content/index.js",
        "features/x-video-download/content/index.js",
        "features/x-image-download/content/index.js",
        "features/youtube/shared.js",
        "features/instagram/shared.js",
        "features/twitter/shared.js"
      ],
      "matches": [
        "https://*.youtube.com/*",
        "https://youtu.be/*",
        "https://*.youtube-nocookie.com/*",
        "https://*.instagram.com/*",
        "https://*.twitter.com/*",
        "https://twitter.com/*",
        "https://*.x.com/*",
        "https://x.com/*"
      ]
    }
  ],
  "options_ui": {
    "page": "popup/popup.html",
    "open_in_tab": true
  }
}
