{
  "name": "all-in-one-extension",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc --project tsconfig.json && node scripts/copy-static.mjs",
    "build:check": "tsc --project tsconfig.json --noEmit",
    "verify": "yarn build:check && yarn validate:manifest && yarn check:repo",
    "check:repo": "node scripts/check-repo.mjs",
    "validate:manifest": "node scripts/validate-manifest.mjs",
    "package:extension": "yarn build && yarn package:extension:nested && yarn package:extension:unpacked",
    "package:extension:nested": "AIO_SOURCE_DIR=extension-dist node scripts/package-extension.mjs",
    "package:extension:unpacked": "AIO_SOURCE_DIR=extension-dist AIO_PACKAGE_LAYOUT=flat node scripts/package-extension.mjs",
    "release:verify": "node scripts/release-verify.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "typescript": "^5.9.3"
  }
}
